# Copy to wrangler.toml (do not commit secrets) or configure in Cloudflare Dashboard.
# Pages: Settings → Functions → D1 bindings + Environment variables

name = "dsa-pattern-practice"
pages_build_output_dir = "."  # adjust if you use a build step

# Code accepts either short bindings below OR bindings named exactly:
#   dsa-pattern-practice-content, dsa-pattern-practice-subscribers
# (see functions/_lib/d1-bindings.js)

[[d1_databases]]
binding = "DB"
database_name = "dsa-pattern-practice-content"
database_id = "<CONTENT_D1_UUID>"

[[d1_databases]]
binding = "DB_SUBSCRIBERS"
database_name = "dsa-pattern-practice-subscribers"
database_id = "<SUBSCRIBERS_D1_UUID>"

# Set in Dashboard → Settings → Environment variables (encrypt):
# USER_JWT_SECRET = "<random 32+ chars>"
