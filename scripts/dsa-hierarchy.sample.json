            "code": "<?php\nfunction binarySearch($arr, $x) {\n    $low = 0;\n    $high = sizeof($arr) - 1;\n    while ($low <= $high) {\n        $mid = $low + ($high - $low) / 2;\n        if ($arr[$mid] == $x)\n            return floor($mid);\n        if ($arr[$mid] < $x)\n            $low = $mid + 1;\n        else\n            $high = $mid - 1;\n    }\n    return -1;\n}"
